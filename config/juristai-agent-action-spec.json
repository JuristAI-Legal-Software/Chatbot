        "responses": { "200": { "description": "No response body" } }
      }
    },
    "/api/core/case-calendar/": {
      "get": {
        "operationId": "get-case-calendar",
        "summary": "Get a calendar view for a case.",
        "description": "Returns case deadlines and docket events for a case the authenticated user can access.",
        "parameters": [
          {
            "in": "query",
            "name": "caseId",
            "schema": { "type": "string", "minLength": 1 },
            "required": true
          },
          { "in": "query", "name": "contains", "schema": { "type": "string", "minLength": 1 } },
          { "in": "query", "name": "dateFrom", "schema": { "type": "string", "minLength": 1 } },
          { "in": "query", "name": "dateTo", "schema": { "type": "string", "minLength": 1 } },
          {
            "in": "query",
            "name": "resultLimit",
            "schema": { "type": "integer", "maximum": 100, "minimum": 1 }
          }
        ],
        "responses": { "200": { "description": "No response body" } }
      }
    },
    "/api/core/case-timeline/": {
      "get": {
        "operationId": "list-case-timeline",
