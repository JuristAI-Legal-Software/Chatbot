  "servers": [{ "url": "https://api-dev.juristai.org" }],
  "paths": {
    "/api/billing/cases/{caseId}/summary": {
      "get": {
        "operationId": "retrieve-case-billing-summary",
        "summary": "Retrieve a billing summary for a case.",
        "description": "Returns a billing summary for a case and billing window the authenticated user can access. summaryText is a JSON-encoded digest with billingHeader, overview metrics, topBillers, topTasks, missedOpportunities (completed work not captured in the total, e.g. no hourly rate set or no time logged), upcoming work due in the next 7 days, and a plainText fallback for direct quoting. Exposed to the LibreChat assistant as a callable tool.",
        "parameters": [
          { "in": "path", "name": "caseId", "schema": { "type": "string" }, "required": true }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "userId": { "type": "string" },
                    "caseId": { "type": "string" },
                    "appId": { "type": "string", "default": "2" },
                    "billingWeekStart": { "type": "string", "format": "date" },
                    "billingWeekEnd": { "type": "string", "format": "date" },
                    "dateFrom": { "type": "string", "format": "date", "nullable": true },
                    "dateTo": { "type": "string", "format": "date", "nullable": true },
                    "resultLimit": { "type": "integer", "minimum": 1, "nullable": true }
                  },
                  "required": ["billingWeekEnd", "billingWeekStart", "caseId", "userId"]
                }
              }
            },
            "description": ""
          }
        }
      }
    },
    "/api/core/assign-user-to-case/": {
      "post": {
        "operationId": "assign-user-to-case",
        "summary": "Assign a user to a case.",
        "description": "Assigns the authenticated user, or an admin-selected user, to a case.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "caseId": { "type": "string" }, "userId": { "type": "string" } },
                "required": ["caseId"]
              }
