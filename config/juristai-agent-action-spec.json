    "/api/core/cases/{caseId}/signatures": {
      "get": {
        "operationId": "list-case-signatures",
        "summary": "List case signatures.",
        "description": "Lists signature requests for a case the authenticated user can access.",
        "parameters": [
          { "in": "path", "name": "caseId", "schema": { "type": "string" }, "required": true },
          {
            "in": "query",
            "name": "limit",
            "schema": { "type": "integer", "minimum": 1, "nullable": true }
          },
          {
            "in": "query",
            "name": "sourceType",
            "schema": {
              "enum": [
                "interview_artifact",
                "uploaded_case_file",
                "uploaded_file",
                "billing_artifact",
                "engagement_letter"
              ],
              "type": "string",
              "minLength": 1
            },
            "description": "* `interview_artifact` - interview_artifact\n* `uploaded_case_file` - uploaded_case_file\n* `uploaded_file` - uploaded_file\n* `billing_artifact` - billing_artifact\n* `engagement_letter` - engagement_letter"
          },
          {
            "in": "query",
            "name": "status",
            "schema": {
              "enum": [
                "DRAFT",
                "PREPARED",
                "SENT",
                "VIEWED",
                "PARTIALLY_SIGNED",
                "COMPLETED",
                "DECLINED",
                "EXPIRED",
                "VOIDED",
                "SYNC_REQUIRED",
                "FAILED"
              ],
              "type": "string",
              "minLength": 1
            },
            "description": "* `DRAFT` - DRAFT\n* `PREPARED` - PREPARED\n* `SENT` - SENT\n* `VIEWED` - VIEWED\n* `PARTIALLY_SIGNED` - PARTIALLY_SIGNED\n* `COMPLETED` - COMPLETED\n* `DECLINED` - DECLINED\n* `EXPIRED` - EXPIRED\n* `VOIDED` - VOIDED\n* `SYNC_REQUIRED` - SYNC_REQUIRED\n* `FAILED` - FAILED"
          }
        ],
        "responses": { "200": { "description": "No response body" } }
      }
    },
    "/api/core/get-case-metadata/": {
