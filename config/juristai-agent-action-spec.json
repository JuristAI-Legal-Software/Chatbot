            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": { "caseId": { "type": "string" }, "userId": { "type": "string" } },
                "required": ["caseId"]
              }
            },
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": { "caseId": { "type": "string" }, "userId": { "type": "string" } },
